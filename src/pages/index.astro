---
import BaseLayout from '../layouts/BaseLayout.astro';

const appStoreUrl = 'https://apps.apple.com/app/id6761666869';
const playStoreUrl = 'https://play.google.com/store/apps/details?id=dev.provable.carpe';
const heroVideos = [
  {
    id: 'PaZRQqWXBtI',
    eyebrow: 'Assets and scans',
    title: 'Data integrity proofs for real-world assets',
    description:
      'NFC/RFID, QR codes, and barcodes captured directly into database records with proof material.',
  },
  {
    id: 'u4pYbgu3GVY',
    eyebrow: 'BLE ingestion',
    title: 'Tamper-evident data ingestion from BLE devices',
    description:
      'Sensor payloads flow into records with decoding, mapping, and integrity tracking at insert time.',
  },
  {
    id: 'EuwNDeDu9Ao',
    eyebrow: 'Any database',
    title: 'Record-level cryptographic integrity',
    description:
      'Create local databases and generate cryptographic proofs for every record as it is written.',
  },
];
---

<BaseLayout
  title="Carpe!"
  description="Capture structured field data with local databases, BLE automations, code scans, NFC tags, and record-level cryptographic integrity."
>
  <Fragment slot="default">
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@graph': [
          {
            '@type': 'MobileApplication',
            name: 'Carpe!',
            operatingSystem: 'iOS, Android',
            applicationCategory: 'BusinessApplication',
            description:
              'Capture structured field data with local databases, BLE automations, code scans, NFC tags, and record-level cryptographic integrity.',
            offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
            installUrl: appStoreUrl,
            author: { '@type': 'Organization', name: 'Kuip Limited' },
          },
          {
            '@type': 'WebSite',
            name: 'Carpe!',
            url: 'https://carpe.provable.dev',
          },
        ],
      })}
    />
  </Fragment>

  <section class="hero">
    <div class="hero-copy">
      <div class="hero-badge">Tamper-evident mobile & desktop data capture</div>
      <h1>Build records you can trust.</h1>
      <p class="hero-sub">
        Carpe! turns a phone into a structured field-data system: local databases,
        BLE sensor ingestion, QR and barcode scanning, NFC tags, GPS capture, and
        record-level cryptographic integrity.
      </p>
      <div class="hero-cta">
        <a href={appStoreUrl} class="btn btn-primary">Download on the App Store</a>
        <a href={playStoreUrl} class="btn btn-outline">Get it on Google Play</a>
        <span class="btn btn-disabled" data-tooltip="coming soon" tabindex="0" aria-disabled="true">Download for macOS</span>
        <span class="btn btn-disabled" data-tooltip="coming soon" tabindex="0" aria-disabled="true">Download for Windows</span>
      </div>
      <p class="hero-note">
        Designed for inspections, asset workflows, chain-of-custody records, research
        capture, and sensor-backed operations.
      </p>
    </div>

    <div class="hero-panel">
      <div class="hero-video-shell carousel-shell">
        <div class="hero-video-head carousel-header">
          <div>
            <strong>See Carpe! in action</strong>
          </div>
          <div class="carousel-controls">
            <button type="button" class="carousel-button" data-carousel-target="hero-video-track" data-direction="prev" aria-label="Previous video">‹</button>
            <button type="button" class="carousel-button" data-carousel-target="hero-video-track" data-direction="next" aria-label="Next video">›</button>
          </div>
        </div>
        <div class="hero-video-track carousel-track" id="hero-video-track">
          {heroVideos.map((video) => (
            <article class="hero-video-card carousel-card video-card">
              <div class="hero-video-frame">
                <iframe
                  src={`https://www.youtube.com/embed/${video.id}`}
                  title={video.title}
                  loading="lazy"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                ></iframe>
              </div>
              <div class="hero-video-meta">
                <div class="hero-video-eyebrow">{video.eyebrow}</div>
                <h3>{video.title}</h3>
                <p>{video.description}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="features">
    <div class="container">
      <h2>Data integrity infrastructure. Customizable.</h2>
      <div class="feature-grid">
        <article class="feature-card">
          <h3>Build local databases fast</h3>
          <p>Create databases, tables, and field types directly on the device so teams can start collecting structured data without a backend.</p>
        </article>
        <article class="feature-card">
          <h3>Capture from forms and sensors</h3>
          <p>Mix manual entry with QR codes, barcodes, NFC tags, GPS coordinates, attachments, and BLE sensor readings in the same workflow.</p>
        </article>
        <article class="feature-card">
          <h3>Automate BLE inserts</h3>
          <p>Configure BLE automations with polling or notifications, decoder mapping, and direct writes into your chosen table.</p>
        </article>
        <article class="feature-card">
          <h3>Keep data on-device</h3>
          <p>Carpe! is local-first. Records stay on the hardware unless the user explicitly exports or integrates them into another workflow.</p>
        </article>
        <article class="feature-card">
          <h3>Verify at record level</h3>
          <p>Each insert can produce cryptographic proof material so tables become tamper-evident over time instead of merely editable logs.</p>
        </article>
        <article class="feature-card">
          <h3>Demo and pilot quickly</h3>
          <p>Ideal for inspections, asset tracking, sensor logging, research capture, and operational teams exploring verifiable data collection.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="audience">
    <div class="container audience-grid">
      <div>
        <h2>Built for critical data</h2>
        <ul>
          <li>Inspection and compliance workflows</li>
          <li>Asset tracking and chain-of-custody records</li>
          <li>Environmental and temperature monitoring</li>
          <li>Research and experimental data capture</li>
          <li>Field ops that combine sensors with human input</li>
        </ul>
      </div>
      <a class="quote-card provable-card" href="https://provable.dev">
        <p>Explore more products at provable.dev</p>
        <span>See the broader product line for timestamping, integrity proofs, and verifiable workflows.</span>
      </a>
    </div>
  </section>

  <script is:inline>
    (() => {
      const buttons = document.querySelectorAll('[data-carousel-target]');
      for (const button of buttons) {
        button.addEventListener('click', () => {
          const targetId = button.getAttribute('data-carousel-target');
          const direction = button.getAttribute('data-direction');
          if (!targetId || !direction) return;
          const track = document.getElementById(targetId);
          if (!track) return;
          const firstCard = track.querySelector('.carousel-card');
          const cardWidth = firstCard instanceof HTMLElement
            ? firstCard.getBoundingClientRect().width + 16
            : track.clientWidth * 0.9;
          const offset = direction === 'next' ? cardWidth : -cardWidth;
          track.scrollBy({ left: offset, behavior: 'smooth' });
        });
      }
    })();
  </script>
</BaseLayout>

<style>
  .container {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .hero {
    max-width: 1120px;
    margin: 0 auto;
    padding: 76px 24px 54px;
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 40px;
    align-items: center;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    padding: 8px 14px;
    margin-bottom: 18px;
    border-radius: 999px;
    background: var(--accent-wash);
    color: var(--accent);
    font-size: 0.92rem;
    letter-spacing: 0.02em;
  }

  .hero h1 {
    font-size: clamp(3rem, 6vw, 5.2rem);
    line-height: 0.95;
    letter-spacing: -0.06em;
    margin-bottom: 18px;
  }

  .hero-sub,
  .hero-note {
    max-width: 640px;
    color: var(--muted);
    font-size: 1.08rem;
  }

  .hero-sub {
    margin-bottom: 24px;
  }

  .hero-note {
    margin-top: 18px;
    font-size: 0.98rem;
  }

  .hero-cta {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-block;
    text-decoration: none;
    padding: 14px 24px;
    border-radius: 999px;
    font-weight: 700;
    transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
  }

  .btn:hover {
    transform: translateY(-2px);
  }

  .btn-primary {
    background: var(--ink);
    color: #fff;
    box-shadow: 0 18px 36px rgba(16, 33, 31, 0.18);
  }

  .btn-outline {
    color: var(--ink);
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.78);
  }

  .btn-disabled {
    position: relative;
    color: rgba(16, 33, 31, 0.48);
    border: 1px dashed rgba(16, 33, 31, 0.18);
    background: rgba(255, 255, 255, 0.42);
    cursor: not-allowed;
  }

  .btn-disabled::after {
    content: attr(data-tooltip);
    position: absolute;
    left: 50%;
    bottom: calc(100% + 10px);
    transform: translateX(-50%) translateY(4px);
    padding: 8px 10px;
    border-radius: 10px;
    background: rgba(16, 33, 31, 0.94);
    color: #fff;
    font-size: 0.82rem;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.18s ease, transform 0.18s ease;
    box-shadow: 0 12px 24px rgba(16, 33, 31, 0.18);
  }

  .btn-disabled:hover::after,
  .btn-disabled:focus-visible::after {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .hero-panel {
    position: relative;
  }

  .hero-video-shell {
    padding: 20px;
    border-radius: 28px;
    background: linear-gradient(180deg, rgba(255,255,255,0.88), rgba(252,250,244,0.94));
    border: 1px solid rgba(16, 33, 31, 0.08);
    box-shadow: var(--shadow);
  }

  .hero-video-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 14px;
    margin-bottom: 16px;
  }

  .hero-video-head p {
    color: var(--muted);
    font-size: 0.92rem;
    max-width: 24rem;
  }

  .carousel-controls {
    display: flex;
    gap: 10px;
  }

  .carousel-button {
    width: 42px;
    height: 42px;
    border: 1px solid rgba(16, 33, 31, 0.14);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.82);
    color: var(--ink);
    font: inherit;
    font-size: 1.4rem;
    cursor: pointer;
  }

  .carousel-track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 100%;
    gap: 16px;
    overflow-x: auto;
    padding-bottom: 8px;
    scroll-snap-type: x mandatory;
    scrollbar-width: thin;
  }

  .carousel-track::-webkit-scrollbar {
    height: 10px;
  }

  .carousel-track::-webkit-scrollbar-thumb {
    background: rgba(16, 33, 31, 0.18);
    border-radius: 999px;
  }

  .hero-video-card {
    scroll-snap-align: start;
    min-height: 100%;
    padding: 0;
    gap: 0;
    border-radius: 22px;
    overflow: hidden;
    background: rgba(16, 33, 31, 0.04);
    border: 1px solid rgba(16, 33, 31, 0.08);
  }

  .hero-video-frame {
    position: relative;
    aspect-ratio: 16 / 9;
    background: #10211f;
  }

  .hero-video-frame iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .hero-video-meta {
    padding: 18px 18px 20px;
  }

  .hero-video-eyebrow {
    margin-bottom: 8px;
    color: var(--accent);
    font-size: 0.84rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
  }

  .hero-video-meta h3 {
    font-size: 1.22rem;
    line-height: 1.2;
    margin-bottom: 8px;
    letter-spacing: -0.03em;
  }

  .hero-video-meta p {
    color: var(--muted);
    font-size: 0.96rem;
  }

  .features,
  .audience {
    padding: 68px 0;
  }

  .features h2,
  .audience h2 {
    margin-bottom: 28px;
    font-size: clamp(2rem, 3vw, 3rem);
    letter-spacing: -0.04em;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }

  .feature-card {
    padding: 24px;
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid var(--border);
    box-shadow: 0 10px 30px rgba(16, 33, 31, 0.05);
  }

  .feature-card h3 {
    margin-bottom: 10px;
    font-size: 1.2rem;
  }

  .feature-card p {
    color: var(--muted);
  }

  .audience-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 22px;
    align-items: start;
  }

  .audience ul {
    padding-left: 22px;
    color: var(--muted);
  }

  .audience li + li {
    margin-top: 8px;
  }

  .quote-card {
    padding: 28px;
    border-radius: 26px;
    background: rgba(16, 33, 31, 0.92);
    color: #f7f5ef;
    box-shadow: var(--shadow);
    text-decoration: none;
    display: block;
  }

  .quote-card p {
    font-size: 1.4rem;
    line-height: 1.35;
    margin-bottom: 18px;
    text-decoration: none;
  }

  .quote-card span {
    color: rgba(247, 245, 239, 0.72);
    font-size: 0.95rem;
    text-decoration: none;
  }

  .provable-card:hover {
    transform: translateY(-2px);
    transition: transform 0.2s ease;
  }

  @media (max-width: 920px) {
    .hero,
    .audience-grid {
      grid-template-columns: 1fr;
    }

    .feature-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding-top: 56px;
    }

    .hero-video-head {
      flex-direction: column;
      align-items: stretch;
    }

    .feature-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
