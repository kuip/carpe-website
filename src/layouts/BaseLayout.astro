---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Carpe! captures structured field data with local databases, BLE automations, and record-level cryptographic integrity.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/og-carpe.png', Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Carpe!" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <div class="page-noise"></div>
    <nav>
      <div class="nav-inner">
        <a href="/" class="brand">
          <img src="/icons/carpe.png" alt="Carpe! icon" width="34" height="34" />
          <span>Carpe!</span>
        </a>
        <div class="nav-links">
          <a href="/privacy">Privacy</a>
          <a href="/terms">Terms</a>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-inner">
        <p>&copy; {new Date().getFullYear()} Kuip Limited. All rights reserved.</p>
        <div class="footer-links">
          <a href="/privacy">Privacy Policy</a>
          <a href="/terms">Terms of Service</a>
          <a href="/delete-account">Delete Account</a>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  :root {
    --ink: #10211f;
    --paper: #f6f5ef;
    --muted: #5d6d68;
    --border: rgba(16, 33, 31, 0.12);
    --panel: rgba(255, 255, 255, 0.82);
    --accent: #0f8f74;
    --accent-2: #ec8a2d;
    --accent-wash: rgba(15, 143, 116, 0.12);
    --radius: 18px;
    --shadow: 0 24px 60px rgba(16, 33, 31, 0.12);
  }

  :global(*) {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :global(html) {
    font-family: Georgia, "Iowan Old Style", "Palatino Linotype", serif;
    color: var(--ink);
    background:
      radial-gradient(circle at top left, rgba(236, 138, 45, 0.14), transparent 28%),
      radial-gradient(circle at top right, rgba(15, 143, 116, 0.18), transparent 30%),
      linear-gradient(180deg, #f5f3e9 0%, #f8f7f2 55%, #f2f1eb 100%);
    line-height: 1.6;
  }

  :global(body) {
    min-height: 100vh;
    position: relative;
  }

  .page-noise {
    position: fixed;
    inset: 0;
    pointer-events: none;
    opacity: 0.06;
    background-image:
      linear-gradient(rgba(16, 33, 31, 0.12) 1px, transparent 1px),
      linear-gradient(90deg, rgba(16, 33, 31, 0.12) 1px, transparent 1px);
    background-size: 24px 24px;
    mask-image: radial-gradient(circle at center, black 40%, transparent 95%);
  }

  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(246, 245, 239, 0.82);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    max-width: 1120px;
    margin: 0 auto;
    padding: 14px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: var(--ink);
    font-weight: 700;
    font-size: 1.2rem;
    letter-spacing: -0.02em;
  }

  .brand img {
    border-radius: 10px;
    box-shadow: 0 8px 20px rgba(16, 33, 31, 0.15);
  }

  .nav-links {
    display: flex;
    gap: 22px;
  }

  .nav-links a,
  .footer-links a {
    text-decoration: none;
    color: var(--muted);
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .nav-links a:hover,
  .footer-links a:hover {
    color: var(--ink);
    transform: translateY(-1px);
  }

  main {
    min-height: calc(100vh - 160px);
  }

  footer {
    border-top: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.42);
  }

  .footer-inner {
    max-width: 1120px;
    margin: 0 auto;
    padding: 28px 24px 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 18px;
  }

  .footer-inner p {
    color: var(--muted);
    font-size: 0.95rem;
  }

  .footer-links {
    display: flex;
    gap: 22px;
    flex-wrap: wrap;
  }

  @media (max-width: 720px) {
    .nav-inner,
    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .nav-links,
    .footer-links {
      gap: 14px;
    }
  }
</style>
